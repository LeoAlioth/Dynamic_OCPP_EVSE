# Docker image for running Home Assistant integration tests
# Build: docker build -t dynamic-ocpp-evse-test -f dev/Dockerfile.test .
# Run: docker run --rm -v $(pwd):/app dynamic-ocpp-evse-test

FROM python:3.11-slim

# Install system dependencies required for Home Assistant
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libffi-dev \
    libssl-dev \
    libjpeg-dev \
    zlib1g-dev \
    tzdata \
    && rm -rf /var/lib/apt/lists/*

# Set up timezone data for tests
# Home Assistant test framework uses US/Pacific which is a legacy symlink
ENV TZ=America/Los_Angeles
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone
# Create US/Pacific symlink for Home Assistant test compatibility
RUN mkdir -p /usr/share/zoneinfo/US && \
    ln -sf /usr/share/zoneinfo/America/Los_Angeles /usr/share/zoneinfo/US/Pacific

# Set working directory
WORKDIR /app

# Copy requirements first for better caching
COPY requirements_dev.txt .

# Install test dependencies with timeout
RUN pip install --no-cache-dir --timeout 600 -r requirements_dev.txt

# Copy the component and tests
COPY . .

# Default command runs all tests
CMD ["python", "-m", "pytest", "dev/tests/", "-v"]